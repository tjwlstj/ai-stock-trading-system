# AI Stock Trading System - Environment Variables
# Copy this file to .env and fill in your actual API keys
# 
# REQUIRED variables are marked with [REQUIRED]
# OPTIONAL variables have default values or are not essential for basic functionality

# ========================================
# 서비스 티어 (정책: config/tiers.yaml)
# ========================================
# free = 분석·조언까지만 (주문/실거래 차단) | paid = 안전장치 하 거래 가능
APP_TIER=free

# ========================================
# 무료 모델 — Google Gemini (Google AI Studio 무료 키)
# 발급: https://aistudio.google.com/app/apikey  (신용카드 불필요)
# 주의: 무료 티어는 입력/출력이 학습에 사용될 수 있음 — 민감정보 전송 금지
# ========================================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ========================================
# 유료 모델 — OpenAI (paid 티어 권장)
# Get your API key from: https://platform.openai.com/api-keys
# ========================================
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=30
OPENAI_MAX_RETRY=5
OPENAI_TEMPERATURE=0.7

# ========================================
# Backend Configuration
# ========================================
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
APP_ENV=development

# ========================================
# CORS Configuration [REQUIRED for Frontend]
# ========================================
# Add your frontend URLs here (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ========================================
# Database Configuration
# ========================================
DATABASE_PATH=data/stock_data.db
DATABASE_BACKUP_ENABLED=true

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# ========================================
# Stock Data Configuration (Optional)
# ========================================
# Yahoo Finance is used by default (no API key required)
YAHOO_FINANCE_TIMEOUT=10
YF_CACHE_DIR=.cache/yf

# ========================================
# Optional Services
# ========================================
# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0

# Cloud Storage (Optional - for data backup)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_BUCKET_NAME=your_bucket_name
AWS_REGION=us-east-1

# ========================================
# 국내(KRX) 트레이딩 설정 — 설계: docs/ARCHITECTURE_KRX.md
# ========================================
# 브로커 선택: paper(기본/시뮬) | kis(모의투자) | toss(실거래)
BROKER=paper
# 실거래 안전장치: toss여도 아래가 true가 아니면 실주문 차단
ALLOW_LIVE_TRADING=false
# 시장 기준
MARKET=KRX
BASE_CURRENCY=KRW

# --- 토스증권 Open API (실거래 타깃, 공식 스펙으로 검증 필요) ---
# 발급: 토스증권 PC 웹 > Open API
TOSS_CLIENT_ID=
TOSS_CLIENT_SECRET=
TOSS_ACCOUNT_NO=
TOSS_BASE_URL=https://openapi.tossinvest.com

# --- 한국투자증권 KIS (개발/모의투자 권장, 무료) ---
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
# 모의투자 도메인 사용 여부
KIS_PAPER=true

# --- RiskGuard 한도 (예시값, 운영 전 반드시 조정) ---
MAX_ORDER_AMOUNT_KRW=100000
MAX_DAILY_LOSS_KRW=200000
MAX_POSITION_PCT=20
